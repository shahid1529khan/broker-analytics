# Supabase project credentials (find these in your Supabase project settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL — leave empty to use Vite proxy (recommended for local dev)
# Set this to your deployed Railway backend URL in production
# VITE_API_URL=https://your-backend.railway.app/api
